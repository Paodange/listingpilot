# ── AI ────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(36))"
JWT_SECRET=replace_with_72_char_random_string
TOKEN_EXPIRE_HOURS=72

# ── Usage limits ──────────────────────────────────────────────────────────────
FREE_DAILY_LIMIT=3
PRO_DAILY_LIMIT=100

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Creem ─────────────────────────────────────────────────────────────────────
# API key: Creem dashboard → Developers → API Keys
# Test-mode keys start with `creem_test_`, live keys start with `creem_`.
CREEM_API_KEY=your_creem_api_key

# Webhook signing secret: Developers → Webhooks → (your endpoint) → Signing Secret
# (Test mode and live mode have separate secrets — match this to whichever
#  endpoint you actually point at this server.)
CREEM_WEBHOOK_SECRET=your_creem_webhook_signing_secret

# Payment link URL: Products → (your product) → Share → Copy payment link
# Test-mode links contain "/test/" in the path; live links do not.
#   Live: https://www.creem.io/payment/prod_xxxxxxxxxx
#   Test: https://www.creem.io/test/payment/prod_xxxxxxxxxx
CREEM_CHECKOUT_URL=https://www.creem.io/test/payment/your_product_id

# Set to "true" while you're using test-mode keys + test-mode payment link.
# The frontend reads this to show a "Test mode" banner on the upgrade button.
CREEM_TEST_MODE=true

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,https://cc.ntotech.top
