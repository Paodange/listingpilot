# ── AI ────────────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(36))"
JWT_SECRET=replace_with_72_char_random_string
TOKEN_EXPIRE_HOURS=72

# ── Usage limits ──────────────────────────────────────────────────────────────
FREE_DAILY_LIMIT=3
PRO_DAILY_LIMIT=100

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── DodoPayments ──────────────────────────────────────────────────────────────
# API key: DodoPayments dashboard → Developers → API Keys
DODOPAYMENTS_API_KEY=your_dodopayments_api_key

# Webhook signing secret: Developers → Webhooks → (your endpoint) → Signing Secret
# Paste the full string including the "whsec_" prefix
DODOPAYMENTS_WEBHOOK_SECRET=whsec_your_signing_secret

# Payment link URL: Products → (your product) → Payment Link → Copy Link
# Example: https://checkout.dodopayments.com/buy/plink_xxxxxxxxxx
DODOPAYMENTS_CHECKOUT_URL=https://checkout.dodopayments.com/buy/your_payment_link_id

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,https://cc.ntotech.top
